generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Section {
  id        Int     @id @default(autoincrement())
  title     String
  slug      String  @unique
  order     Int
  isVisible Boolean @default(true)
  works     Work[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Work {
  id          Int      @id @default(autoincrement())
  title       String
  client      String
  videoUrl    String
  thumbnail   String
  description String
  tags        String[]
  isVisible   Boolean  @default(true)
  order       Int
  section     Section  @relation(fields: [sectionId], references: [id])
  sectionId   Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Client {
  id        Int     @id @default(autoincrement())
  name      String
  logo      String
  order     Int
  isVisible Boolean @default(true)
}

model SiteConfig {
  id    Int    @id @default(autoincrement())
  key   String @unique
  value String
}
